# CITIWAY — ENVIRONMENT VARIABLE TEMPLATE
# ═══════════════════════════════════════════════════════════════
# HOW TO USE
#   1. Copy this file:   cp .env.example .env.local
#   2. Fill in the real values from your Supabase project
#   3. NEVER commit .env or .env.local — only this .env.example is tracked
#
# WHERE TO GET THESE
#   Supabase Dashboard → Project Settings → API
# ═══════════════════════════════════════════════════════════════

# ---- PUBLIC (safe to expose in the browser) --------------------
# These are prefixed NEXT_PUBLIC_ and are shipped to the client by design.
# Security still relies on Supabase Row Level Security (RLS), not on hiding these.

# Your project URL, e.g. https://abcdefghijklmno.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# The "anon" public API key (JWT). Public by design; protect data via RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---- SERVER-ONLY (NEVER prefix with NEXT_PUBLIC_) --------------
# Only add these if/when you introduce server-side code (Route Handlers,
# Server Actions, middleware). Keep them OUT of the client bundle.
# The service_role key bypasses RLS — treat it like a root password.
# SUPABASE_SERVICE_ROLE_KEY=
